{
    "languageserver": {
        "bash": {
            "command": "bash-language-server",
            "args": [
                "start"
            ],
            "filetypes": [
                "sh"
            ],
            "ignoredRootPaths": [
                "~"
            ]
        },
        "ccls": {
            "command": "ccls",
            "filetypes": [
                "c",
                "cpp",
                "cuda",
                "objc",
                "objcpp"
            ],
            "rootPatterns": [
                ".ccls",
                "compile_commands.json",
                ".vim/",
                ".git/",
                ".hg/"
            ],
            "initializationOptions": {
                "cache": {
                    "directory": "/tmp/ccls-cache"
                }
            }
        }
    },
    "python.jediEnabled": false,
    "python.pythonPath": "/Users/horta/anaconda3/bin/python3",
    "python.formatting.provider": "black",
    "python.linting.flake8Enabled": true,
    "python.linting.flake8Path": "/Users/horta/anaconda3/bin/flake8",
    "python.linting.banditEnabled": true,
    "python.linting.banditPath": "/Users/horta/anaconda3/bin/bandit",
    "python.linting.mypyEnabled": true,
    "python.linting.mypyPath": "/Users/horta/anaconda3/bin/mypy",
    "python.sortImports.path": "/Users/horta/anaconda3/bin/isort",
    "coc.preferences.formatOnSaveFiletypes": [
        "css",
        "Markdown",
        "json",
        "python",
        "rust"
    ]
}

#!/usr/bin/env bash

echo "##################################"
echo "Welcome to Danilo Horta's dotfiles"
echo "##################################"
echo ""

echo "Home: $HOME"
cd $HOME

if ! type git >/dev/null
then
    echo "ERROR: Git has not been found!"
    exit 1
fi

if ! type conda >/dev/null 2>&1
then
    echo "ERROR: Conda has not been found!"
    exit 1
fi

function create_expected_dirs()
{
    mkdir -p $HOME/bin || true
    mkdir -p $HOME/code || true
    mkdir -p $HOME/.config || true
}
create_expected_dirs

echo "Creating $HOME/bin/conda-init.fish"
conda shell.fish hook > $HOME/bin/conda-fish-init.fish

echo "Creating $HOME/bin/conda-bash-init.sh"
conda shell.bash hook > $HOME/bin/conda-bash-init.sh

function config()
{
    /usr/bin/env git --git-dir=$HOME/.cfg/ --work-tree=$HOME $@
}

git config --global user.email "danilo.horta@gmail.com"
git config --global user.name "Danilo Horta"
git config --global push.default current
git config --global credential.helper 'cache --timeout 3600000'

function config_dotfiles_repo()
{
    if test -e $HOME/.cfg
    then
        echo "Dotfiles repo: $HOME/.cfg"
        config fetch --all -q
        config checkout master -q
        config reset --hard HEAD -q
        config pull -q
    else
        echo "Creating my dotfiles repository."
        git clone --bare https://github.com/horta/dotfiles.git $HOME/.cfg -q
    fi
    config config --local status.showUntrackedFiles no
    config checkout --force -q >/dev/null
}
config_dotfiles_repo

echo ""
echo "Configuring tmux"
echo "----------------"
if test -e $HOME/.tmux
then
    cd $HOME/.tmux && git pull && cd $HOME
else
    git clone https://github.com/gpakosz/.tmux.git .tmux
fi

echo ""
echo "Configuring fish shell"
echo "----------------------"
mkdir -p $HOME/.config/fish/functions || true
fish -c "type -q fisher; and fisher self-uninstall" >/dev/null
curl https://git.io/fisher --create-dirs -sLo ~/.config/fish/functions/fisher.fish -q
fish -c "fisher self-update" >/dev/null
fish -c "fisher add edc/bass" >/dev/null
fish -c "fisher add jethrokuan/fzf" >/dev/null


echo ""
echo "Configuring nvim"
echo "----------------"

type pip >/dev/null 2>&1  && pip install --user --upgrade pynvim
type pip2 >/dev/null 2>&1 && pip2 install --user --upgrade pynvim
type pip3 >/dev/null 2>&1 && pip3 install --user --upgrade pynvim

if type nvim >/dev/null 2>&1;
then
    nvim +PlugClean! +qall
    nvim +PlugUpgrade +qall
    nvim +PlugUpdate +qall
    nvim +UpdateRemotePlugins +qall
fi
